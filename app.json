{
  "expo": {
    "name": "Clearview Savings",
    "slug": "clearview-savings-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "clearviewsavings",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearviewsavings.mobile"
    },
    "android": {
      "package": "com.clearviewsavings.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#1f2a37"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "69f6c9ee-c8fa-424f-86c1-3ddf80fbe294"
      }
    },
    "owner": "talnerith"
  }
}
