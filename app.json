{
  "expo": {
    "name": "Clearview Savings",
    "slug": "clearview-savings-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "clearviewsavings",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearviewsavings.mobile"
    },
    "android": {
      "package": "com.clearviewsavings.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#19293A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#19293A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "69f6c9ee-c8fa-424f-86c1-3ddf80fbe294"
      }
    },
    "owner": "talnerith"
  }
}
