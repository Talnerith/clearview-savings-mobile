# Clearview Savings Mobile — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored; never commit real secrets. Variables prefixed with EXPO_PUBLIC_
# are embedded in the app bundle by design (same trust model as the web app's
# NEXT_PUBLIC_ keys) — only ever put the *publishable* / anon-tier values here,
# never the Supabase secret/service key.
#
# These point at the SAME Supabase project as the clearview-savings web app, so
# the mobile app authenticates against the same Auth users and reads data
# through the same Row-Level Security policies. No separate backend.

# Supabase project URL — copy from the web app's NEXT_PUBLIC_SUPABASE_URL.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase publishable key — copy from the web app's
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (sb_publishable_...). Safe to embed.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Cloudflare Turnstile PUBLIC site key — copy from the web app's
# NEXT_PUBLIC_TURNSTILE_SITE_KEY. The project enforces Turnstile on Auth, so
# real sign-in needs this; without it the app still runs in demo mode. Never
# the Turnstile SECRET key (that lives only in the Supabase dashboard).
EXPO_PUBLIC_TURNSTILE_SITE_KEY=0x...

# On NATIVE (iOS/Android) the Turnstile widget runs in a WebView; Cloudflare
# checks the document hostname against the site key's allowed domains. We set
# the WebView baseUrl to this host so it matches. Must be a domain the site key
# permits (default: the production web origin). Web build ignores this.
EXPO_PUBLIC_TURNSTILE_HOST=https://clearviewsavings.com

# Base URL of the web app's deployment that hosts the mobile API endpoints
# (app/api/m/*). Production origin; use a Vercel preview URL when testing a
# branch. Used by lib/api.ts. Set this in the EAS build env for release APKs.
EXPO_PUBLIC_API_BASE_URL=https://clearviewsavings.com
